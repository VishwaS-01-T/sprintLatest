generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id                 String               @id @default(uuid())
  firstName          String               @db.VarChar(100)
  lastName           String               @db.VarChar(100)
  email              String               @unique @db.VarChar(255)
  passwordHash       String               @db.VarChar(255)
  roleId             String
  profileImage       String?
  accountStatus      AdminAccountStatus   @default(ACTIVE)
  lastLogin          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  role               Role                 @relation("AdminRole", fields: [roleId], references: [id])
  activityLogs       AdminActivityLog[]
  sessions           AdminSession[]
  cancelledOrders    Order[]              @relation("OrderCancelledBy")
  orderStatusChanges OrderStatusHistory[] @relation("OrderStatusChangedBy")
  moderatedReviews   ProductReview[]      @relation("ReviewModeration")

  @@index([email])
  @@index([roleId])
  @@index([accountStatus])
}

model Role {
  id          String   @id @default(uuid())
  roleName    String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admins      Admin[]  @relation("AdminRole")

  @@index([roleName])
}

model AdminSession {
  id           String   @id @default(uuid())
  adminId      String
  device       String?  @db.VarChar(255)
  ipAddress    String?  @db.VarChar(50)
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model AdminActivityLog {
  id         String          @id @default(uuid())
  adminId    String
  action     AdminActionType
  entityType String          @db.VarChar(100)
  entityId   String?         @db.VarChar(255)
  oldData    String?
  newData    String?
  timestamp  DateTime        @default(now())
  admin      Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([timestamp])
}

model Coupon {
  id                   String       @id @default(uuid())
  code                 String       @unique @db.VarChar(50)
  description          String?
  discountType         DiscountType
  discountValue        Float
  minimumOrderValue    Float?
  maximumDiscount      Float?
  usageLimit           Int?
  usedCount            Int          @default(0)
  startDate            DateTime
  expiryDate           DateTime
  status               CouponStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  applicableCategories String?
  excludedProducts     String?
  isFirstPurchaseOnly  Boolean      @default(false)
  maxUsesPerUser       Int?
  appliedCarts         Cart[]

  @@index([code])
  @@index([status])
  @@index([expiryDate])
}

model Collection {
  id           String           @id @default(uuid())
  name         String           @unique @db.VarChar(255)
  slug         String           @unique @db.VarChar(255)
  description  String?
  imageUrl     String?
  displayOrder Int              @default(0)
  status       CollectionStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  products     Product[]        @relation("ProductCollection")

  @@index([slug])
  @@index([status])
  @@index([displayOrder])
}

model Category {
  id            String         @id @default(uuid())
  name          String         @unique @db.VarChar(255)
  slug          String         @unique @db.VarChar(255)
  description   String?
  imageUrl      String?
  displayOrder  Int            @default(0)
  parentId      String?
  status        CategoryStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories Category[]     @relation("CategoryHierarchy")
  products      Product[]      @relation("ProductCategory")

  @@index([slug])
  @@index([status])
  @@index([parentId])
  @@index([displayOrder])
}

model Cart {
  id              String     @id @default(uuid())
  customerId      String     @unique
  sessionId       String?    @unique @db.VarChar(255)
  totalItems      Int        @default(0)
  totalPrice      Float      @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  appliedCouponId String?
  appliedDiscount Float      @default(0)
  appliedCoupon   Coupon?    @relation(fields: [appliedCouponId], references: [id])
  customer        User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items           CartItem[]

  @@index([customerId])
  @@index([appliedCouponId])
}

model SavedItem {
  id         String         @id @default(uuid())
  customerId String
  productId  String
  variantId  String
  size       String         @db.VarChar(50)
  color      String         @db.VarChar(100)
  quantity   Int
  unitPrice  Float
  savedAt    DateTime       @default(now())
  customer   User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([productId])
  @@index([variantId])
}

model CartItem {
  id         String         @id @default(uuid())
  cartId     String
  productId  String
  variantId  String
  size       String         @db.VarChar(50)
  color      String         @db.VarChar(100)
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  cart       Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@index([cartId, createdAt])
}

model Inventory {
  id               String         @id @default(uuid())
  variantId        String         @unique
  stockQuantity    Int            @default(0)
  reservedStock    Int            @default(0)
  availableStock   Int            @default(0)
  reorderThreshold Int
  lastUpdated      DateTime       @updatedAt
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Order {
  id                 String               @id @default(uuid())
  orderNumber        String               @unique @db.VarChar(50)
  customerId         String
  orderStatus        OrderStatus          @default(PENDING)
  paymentStatus      PaymentStatus        @default(PENDING)
  fulfillmentStatus  FulfillmentStatus    @default(PENDING)
  subtotal           Float
  taxAmount          Float
  shippingCost       Float
  discountAmount     Float                @default(0)
  totalAmount        Float
  currency           String               @default("USD") @db.VarChar(3)
  placedAt           DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledBy        String?
  deliveredAt        DateTime?
  estimatedDelivery  DateTime?
  notes              String?
  trackingUrl        String?
  cancelledByAdmin   Admin?               @relation("OrderCancelledBy", fields: [cancelledBy], references: [id])
  customer           User                 @relation(fields: [customerId], references: [id])
  addresses          OrderAddress?
  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  payments           Payment[]
  refunds            Refund[]
  returnRequests     ReturnRequest[]
  shipments          Shipment[]

  @@index([customerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([fulfillmentStatus])
  @@index([placedAt])
  @@index([cancelledBy])
}

model OrderItem {
  id                  String         @id @default(uuid())
  orderId             String
  productId           String
  variantId           String
  productNameSnapshot String         @db.VarChar(255)
  size                String         @db.VarChar(50)
  color               String         @db.VarChar(100)
  quantity            Int
  price               Float
  total               Float
  createdAt           DateTime       @default(now())
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product        @relation(fields: [productId], references: [id])
  variant             ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model OrderAddress {
  id              String   @id @default(uuid())
  orderId         String   @unique
  shippingAddress String
  billingAddress  String
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ReturnRequest {
  id           String       @id @default(uuid())
  orderId      String
  customerId   String
  reason       String
  returnStatus ReturnStatus @default(PENDING)
  requestedAt  DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        ReturnItem[]
  customer     User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([customerId])
  @@index([returnStatus])
}

model ReturnItem {
  id            String        @id @default(uuid())
  returnId      String
  orderItemId   String
  quantity      Int
  refundAmount  Float
  createdAt     DateTime      @default(now())
  returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model Payment {
  id              String          @id @default(uuid())
  orderId         String
  paymentMethod   PaymentMethod
  paymentProvider PaymentProvider
  transactionId   String?         @unique @db.VarChar(255)
  paymentStatus   PaymentStatus   @default(PENDING)
  amount          Float
  currency        String          @default("USD") @db.VarChar(3)
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds         Refund[]

  @@index([orderId])
  @@index([transactionId])
  @@index([paymentStatus])
}

model Refund {
  id           String       @id @default(uuid())
  paymentId    String
  orderId      String
  refundAmount Float
  refundReason String
  refundStatus RefundStatus @default(PENDING)
  processedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([orderId])
  @@index([refundStatus])
}

model Product {
  id                String             @id @default(uuid())
  name              String             @db.VarChar(255)
  slug              String             @unique @db.VarChar(255)
  brand             String             @db.VarChar(255)
  description       String?
  shortDescription  String?            @db.VarChar(500)
  gender            Gender
  shoeType          String             @db.VarChar(100)
  category          String             @db.VarChar(255)
  releaseDate       DateTime?
  basePrice         Float
  featuredProduct   Boolean            @default(false)
  newArrival        Boolean            @default(false)
  status            ProductStatus      @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  categoryId        String?
  collectionId      String?
  dimensions        String?
  metaDescription   String?
  metaKeywords      String?
  metaTitle         String?            @db.VarChar(255)
  sku               String?            @unique @db.VarChar(100)
  weight            Float?
  cartItems         CartItem[]
  orderItems        OrderItem[]
  priceAlerts       PriceAlert[]
  categoryRef       Category?          @relation("ProductCategory", fields: [categoryId], references: [id])
  collection        Collection?        @relation("ProductCollection", fields: [collectionId], references: [id])
  images            ProductImage[]
  reviews           ProductReview[]
  variants          ProductVariant[]
  savedItems        SavedItem[]
  shoeSpecification ShoeSpecification?
  sizeGuides        SizeGuide[]
  wishlistItems     WishlistItem[]

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([collectionId])
  @@index([categoryId])
  @@index([brand])
  @@index([newArrival])
  @@index([featuredProduct])
}

model ProductVariant {
  id            String         @id @default(uuid())
  productId     String
  sku           String         @unique @db.VarChar(100)
  size          String         @db.VarChar(50)
  material      String?        @db.VarChar(255)
  color         String         @db.VarChar(100)
  width         String?        @db.VarChar(50)
  price         Float
  comparePrice  Float?
  weight        Float?
  barcode       String?        @unique @db.VarChar(100)
  status        ProductStatus  @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cartItems     CartItem[]
  inventory     Inventory?
  orderItems    OrderItem[]
  images        ProductImage[]
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  savedItems    SavedItem[]
  wishlistItems WishlistItem[]

  @@index([productId])
  @@index([sku])
  @@index([color])
}

model ProductImage {
  id          String          @id @default(uuid())
  productId   String
  variantId   String?
  imageUrl    String
  altText     String?         @db.VarChar(255)
  position    Int             @default(0)
  isThumbnail Boolean         @default(false)
  createdAt   DateTime        @default(now())
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
}

model ProductTag {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  @@index([slug])
}

model ShoeSpecification {
  id             String   @id @default(uuid())
  productId      String   @unique
  material       String?  @db.VarChar(255)
  soleMaterial   String?  @db.VarChar(255)
  upperMaterial  String?  @db.VarChar(255)
  cushioningType String?  @db.VarChar(100)
  heelHeight     Float?
  closureType    String?  @db.VarChar(100)
  waterproof     Boolean  @default(false)
  breathable     Boolean  @default(false)
  weight         Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model SizeGuide {
  id         String     @id @default(uuid())
  productId  String
  sizeSystem SizeSystem
  sizeValue  String     @db.VarChar(50)
  footLength Float?
  createdAt  DateTime   @default(now())
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sizeSystem, sizeValue])
  @@index([productId])
}

model ProductReview {
  id               String       @id @default(uuid())
  customerId       String
  productId        String
  rating           Int
  reviewTitle      String       @db.VarChar(255)
  reviewText       String?
  images           String?
  verifiedPurchase Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  moderatedAt      DateTime?
  moderatedBy      String?
  moderationNote   String?
  status           ReviewStatus @default(PENDING)
  customer         User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  moderator        Admin?       @relation("ReviewModeration", fields: [moderatedBy], references: [id])
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([productId])
  @@index([rating])
  @@index([status])
  @@index([productId, status])
  @@index([customerId, createdAt])
}

model Shipment {
  id             String         @id @default(uuid())
  orderId        String
  courierName    String         @db.VarChar(100)
  trackingNumber String?        @unique @db.VarChar(255)
  shippingMethod String         @db.VarChar(100)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  shippingStatus ShippingStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([trackingNumber])
  @@index([shippingStatus])
}

model ShippingMethod {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(100)
  description           String?
  cost                  Float
  estimatedDeliveryDays Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([name])
}

model TaxRule {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  region    String?  @db.VarChar(100)
  taxRate   Float
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([region])
  @@index([isActive])
  @@index([priority])
}

model ShippingRule {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  region         String?  @db.VarChar(100)
  minimumOrder   Float    @default(0)
  maximumOrder   Float?
  shippingCost   Float
  isFreeShipping Boolean  @default(false)
  isActive       Boolean  @default(true)
  priority       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([region])
  @@index([isActive])
  @@index([priority])
}

model User {
  id                  String               @id @default(uuid())
  firstName           String               @db.VarChar(100)
  lastName            String               @db.VarChar(100)
  email               String               @unique @db.VarChar(255)
  passwordHash        String               @db.VarChar(255)
  phoneNumber         String               @unique @db.VarChar(20)
  status              UserStatus           @default(ACTIVE)
  emailVerified       Boolean              @default(false)
  phoneVerified       Boolean              @default(false)
  lastLogin           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  gender              Gender
  dateOfBirth         DateTime
  deletedAt           DateTime?
  loyaltyPoints       Int                  @default(0)
  preferences         String?
  profileImage        String?
  referralCode        String?              @unique @db.VarChar(50)
  referredById        String?
  addresses           Address[]
  cart                Cart?
  orders              Order[]
  priceAlerts         PriceAlert[]
  reviews             ProductReview[]
  returnRequests      ReturnRequest[]
  savedItems          SavedItem[]
  savedPaymentMethods SavedPaymentMethod[]
  referredBy          User?                @relation("UserReferrals", fields: [referredById], references: [id])
  referrals           User[]               @relation("UserReferrals")
  sessions            UserSession[]
  wishlist            Wishlist?

  @@index([email])
  @@index([phoneNumber])
  @@index([status])
  @@index([referralCode])
  @@index([deletedAt])
  @@index([referredById])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  device       String?  @db.VarChar(255)
  ipAddress    String?  @db.VarChar(50)
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model Address {
  id                String    @id @default(uuid())
  userId            String
  fullName          String    @db.VarChar(255)
  phone             String    @db.VarChar(20)
  addressLine1      String    @db.VarChar(255)
  addressLine2      String?   @db.VarChar(255)
  city              String    @db.VarChar(100)
  state             String    @db.VarChar(100)
  postalCode        String    @db.VarChar(20)
  landmark          String?   @db.VarChar(255)
  latitude          Float?
  longitude         Float?
  isDefaultShipping Boolean   @default(false)
  isDefaultBilling  Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  validated         Boolean   @default(false)
  validatedAt       DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postalCode])
  @@index([city, state])
}

model Wishlist {
  id         String         @id @default(uuid())
  customerId String         @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  customer   User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]

  @@index([customerId])
}

model WishlistItem {
  id          String          @id @default(uuid())
  wishlistId  String
  productId   String
  variantId   String?
  addedAt     DateTime        @default(now())
  priceAlerts PriceAlert[]
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  wishlist    Wishlist        @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@index([wishlistId])
  @@index([productId])
  @@index([variantId])
  @@index([wishlistId, addedAt])
}

model SavedPaymentMethod {
  id            String          @id @default(uuid())
  userId        String
  provider      PaymentProvider
  paymentMethod PaymentMethod
  token         String          @db.VarChar(255)
  cardBrand     String?         @db.VarChar(50)
  cardLast4     String?         @db.VarChar(4)
  cardExpMonth  Int?
  cardExpYear   Int?
  upiId         String?         @db.VarChar(255)
  isDefault     Boolean         @default(false)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([isDefault])
}

model PriceAlert {
  id             String        @id @default(uuid())
  userId         String
  productId      String
  wishlistItemId String?
  targetPrice    Float
  currentPrice   Float
  isActive       Boolean       @default(true)
  triggeredAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlistItem   WishlistItem? @relation(fields: [wishlistItemId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([isActive])
  @@index([wishlistItemId])
}

model OrderStatusHistory {
  id                    String             @id @default(uuid())
  orderId               String
  fromOrderStatus       OrderStatus?
  toOrderStatus         OrderStatus?
  fromPaymentStatus     PaymentStatus?
  toPaymentStatus       PaymentStatus?
  fromFulfillmentStatus FulfillmentStatus?
  toFulfillmentStatus   FulfillmentStatus?
  note                  String?
  changedByAdminId      String?
  changedAt             DateTime           @default(now())
  changedByAdmin        Admin?             @relation("OrderStatusChangedBy", fields: [changedByAdminId], references: [id])
  order                 Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([changedByAdminId])
  @@index([changedAt])
}

enum AdminAccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum AdminActionType {
  CREATE
  UPDATE
  DELETE
  ACTIVATE
  DEACTIVATE
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum CollectionStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
  WALLET
  UPI
  COD
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  PAYPAL
  INTERNAL
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum Gender {
  MEN
  WOMEN
  UNISEX
  KIDS
}

enum ProductStatus {
